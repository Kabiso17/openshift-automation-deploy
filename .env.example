# ============================================================
# OCP Automation UI — 部署設定
# 複製此檔案為 .env 並填入你的環境值
#   cp .env.example .env
# ============================================================

# Mirror Registry 位址（mirror-registry 安裝後的位址，預設 port 8443）
# 範例：REGISTRY=bastion.example.com:8443/ocp-automation
REGISTRY=<your-registry-host>:8443/ocp-automation

# Image tag（latest 或指定版本，例如 v1.2.0）
IMAGE_TAG=latest

# UI 對外 port（預設 80）
UI_PORT=80

# Pull secret 路徑（用於 oc-mirror 認證，預設 /root/pull-secret）
PULL_SECRET_PATH=/root/pull-secret
